{
  "expo": {
    "name": "AiCar",
    "slug": "aicar-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aicar",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deponla.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yak\u0131n\u0131ndaki depolar\u0131 g\u00f6sterebilmemiz i\u00e7in konumuna ihtiyac\u0131m\u0131z var.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Yak\u0131n\u0131ndaki depolar\u0131 g\u00f6sterebilmemiz i\u00e7in konumuna ihtiyac\u0131m\u0131z var."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.deponla.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDxDF6TiS6JKM-tsyEmzH3AQytwbhFfnXg"
        }
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "rn-mrz-scanner",
        {
          "cameraPermissionText": "We need camera access to scan your document's MRZ."
        }
      ],
      [
        "rn-passport-reader",
        {
          "masterListPem": "./assets/bundle.pem"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Yak\u0131n\u0131ndaki depolar\u0131 g\u00f6sterebilmemiz i\u00e7in konumuna ihtiyac\u0131m\u0131z var.",
          "locationAlwaysPermission": "Yak\u0131n\u0131ndaki depolar\u0131 g\u00f6sterebilmemiz i\u00e7in konumuna ihtiyac\u0131m\u0131z var.",
          "locationWhenInUsePermission": "Yak\u0131n\u0131ndaki depolar\u0131 g\u00f6sterebilmemiz i\u00e7in konumuna ihtiyac\u0131m\u0131z var.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}